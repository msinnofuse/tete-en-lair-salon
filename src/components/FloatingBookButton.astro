---
import { getTranslations, type Language } from '../i18n/utils';

export interface Props {
  currentLang?: Language;
}

const { currentLang = 'de' } = Astro.props;
const t = getTranslations(currentLang);
---

<!-- Floating Book Button - Mobile Only -->
<a
  href="https://salonkee.ch/salon/tete-en-lair"
  target="_blank"
  rel="noopener noreferrer"
  id="floating-book-btn"
  class="floating-book-btn"
  aria-label={t.contact.book_online}
>
  <!-- Tooltip -->
  <span class="tooltip font-nav">{t.contact.book_online}</span>
  <!-- Calendar Icon -->
  <svg xmlns="http://www.w3.org/2000/svg" class="btn-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
  </svg>
</a>

<style>
  .floating-book-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: var(--navy-blue);
    color: white;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .floating-book-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .floating-book-btn:active {
    transform: scale(0.95);
  }

  .btn-icon {
    width: 24px;
    height: 24px;
  }

  /* Tooltip styling - dark glass */
  .tooltip {
    position: absolute;
    right: 100%;
    margin-right: 14px;
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: white;
    font-size: 13px;
    letter-spacing: 0.02em;
    white-space: nowrap;
    border-radius: 20px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
    transform: translateX(8px);
  }

  .floating-book-btn:hover .tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }

</style>
