---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getTranslations, type Language } from '../../i18n/utils';
import heroImage from '../../assets/images/hero-images/chair-1.jpg';

const currentLang: Language = 'en';
const t = getTranslations(currentLang);
---

<Layout title={t.seo.contact.title} description={t.seo.contact.description} lang={currentLang} heroImage={heroImage}>
  <style>
    body {
      background: white !important;
    }
  </style>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="h-96 md:h-[500px] relative overflow-hidden flex items-center justify-center" style="clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%); filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.3));">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <Image
          src={heroImage}
          alt="Salon interior"
          class="w-full h-full object-cover"
          style="object-position: center 75%; filter: brightness(1.3) contrast(0.9);"
          widths={[640, 960, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          quality={80}
        />
        <!-- White overlay for better readability -->
        <div class="absolute inset-0 bg-white opacity-15"></div>
      </div>

    </section>

    <!-- Contact Section -->
    <section class="py-32 relative" style="background: white;">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="sr-only">Contact & Opening Hours</h2>
        <!-- Contact Information - Centered Layout -->
        <div class="max-w-xl mx-auto">
          <div class="space-y-16">
            <!-- Primary Contact Details -->
            <div class="text-center space-y-6">
              <div class="space-y-5">
                <a href="https://maps.app.goo.gl/zNzCqSuc5unB5og17" target="_blank" rel="noopener noreferrer" class="font-body text-2xl leading-relaxed hover:opacity-70 transition-opacity block">
                  {t.contact.address}
                </a>

                <!-- Booking Options -->
                <div class="pt-2 flex items-center justify-center gap-4">
                  <a href="https://salonkee.ch/salon/tete-en-lair" target="_blank" rel="noopener noreferrer" class="font-body text-xl leading-relaxed hover:opacity-70 transition-opacity border-b border-gray-300">
                    {t.contact.book_online}
                  </a>
                  <span class="font-body text-xl opacity-30">·</span>
                  <a href={`tel:${t.contact.phone.replace(/\s/g, '')}`} class="font-body text-xl leading-relaxed hover:opacity-70 transition-opacity">
                    {t.contact.phone}
                  </a>
                </div>

                <!-- Instagram -->
                <div class="pt-2 flex items-center justify-center">
                  <a href="https://www.instagram.com/tete_en_l_air_basel" target="_blank" rel="noopener noreferrer" class="opacity-50 hover:opacity-80 transition-opacity" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Opening Hours -->
            <div class="text-center space-y-5">
              <h3 class="text-lg font-heading opacity-80">{t.contact.hours_title}</h3>
              <div class="font-body text-base opacity-70">
                <span class="font-medium">{t.contact.hours.weekdays}</span>
                <span class="ml-3">{t.contact.hours.weekdays_time}</span>
              </div>
            </div>

            <!-- Holzpark Klybeck -->
            <div class="text-center space-y-4">
              <h3 class="text-lg font-heading opacity-80">Holzpark Klybeck</h3>
              <p class="font-body text-sm opacity-60 leading-relaxed max-w-md mx-auto">
                A creative arts district directly on the Rhine. A breeding ground for fine and truly extraordinary things.
              </p>
              <a href="https://www.holzpark-klybeck.ch" target="_blank" rel="noopener noreferrer" class="font-body text-sm opacity-50 hover:opacity-70 transition-opacity block">
                www.holzpark-klybeck.ch
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>